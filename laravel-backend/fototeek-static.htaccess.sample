# ZoneOS / Fototeek docroot — route SPA through PHP shell (index.php) so HTML is not aggressively cached.
# Copy to: ~/domeenid/www.ta24aksalu.itmajakas.ee/fototeek/.htaccess

RewriteEngine On

DirectoryIndex index.php index.html

# Homepage → PHP shell (fresh Cache-Control every request).
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^ current/public/index.php [L]

# Client-side routes → same PHP shell.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ current/public/index.php [L]

# Hashed Vite assets stay cache-friendly (filenames change each build).
FileETag None

<IfModule mod_headers.c>
  Header always set Cache-Control "private, no-store, no-cache, must-revalidate, max-age=0" "expr=%{CONTENT_TYPE} =~ m#text/html#"
  Header always set Pragma "no-cache" "expr=%{CONTENT_TYPE} =~ m#text/html#"
  Header always set Expires "Wed, 11 Jan 1984 05:00:00 GMT" "expr=%{CONTENT_TYPE} =~ m#text/html#"
  Header always unset Last-Modified "expr=%{CONTENT_TYPE} =~ m#text/html#"
</IfModule>
